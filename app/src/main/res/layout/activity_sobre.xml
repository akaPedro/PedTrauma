<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundo_cinza"
    android:orientation="vertical"
    tools:context=".SobreActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/black"
        app:navigationIcon="@drawable/ic_voltar"
        app:navigationContentDescription="@string/desc_voltar"
        app:title="@string/titulo_sobre"
        app:titleTextColor="@color/white"
        app:titleCentered="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <ImageView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/desc_logo"
                android:src="@drawable/logonormpng" />

            <TextView
                android:id="@+id/txtSobre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:autoLink="email"
                android:lineSpacingExtra="5dp"
                android:text="@string/sobre_texto"
                android:textColor="@color/texto_escuro"
                android:textColorLink="@color/azul_pedtrauma"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtInfoSobre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:autoLink="email"
                android:background="@drawable/bg_caixa_texto"
                android:lineSpacingExtra="6dp"
                android:padding="16dp"
                android:textColor="@color/texto_escuro"
                android:textColorLink="@color/azul_pedtrauma"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
