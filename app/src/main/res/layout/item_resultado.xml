<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_circulo_verde"
            android:gravity="center"
            android:text="@string/interrogacao"
            android:textColor="@color/white"
            android:textSize="44sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rotulo_pontuacao"
                android:textColor="@color/texto_escuro"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/badgePontuacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_badge_pontuacao"
                android:minWidth="48dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/pontuacao_pendente"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtInterpretacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/texto_escuro"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_gravity="start"
            android:text="@string/pergunta_exame_imagem"
            android:textColor="@color/texto_escuro"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/grupoExame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/exameSim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/texto_escuro"
                android:text="@string/opcao_sim"
                android:textColor="@color/texto_escuro"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/exameNao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/texto_escuro"
                android:text="@string/opcao_nao"
                android:textColor="@color/texto_escuro"
                android:textStyle="bold" />
        </RadioGroup>

        <EditText
            android:id="@+id/edtAchados"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_caixa_texto"
            android:gravity="top|start"
            android:hint="@string/hint_achados"
            android:importantForAutofill="no"
            android:inputType="textMultiLine|textCapSentences"
            android:padding="12dp"
            android:textColor="@color/texto_escuro"
            android:textColorHint="@color/texto_escuro"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutAviso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_aviso_vermelho"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/pergunta_exame_imagem"
                android:src="@drawable/ic_aviso" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/aviso_hemorragia"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSalvarAvaliacao"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_botao_azul"
            android:text="@string/btn_salvar_avaliacao"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressSalvar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
