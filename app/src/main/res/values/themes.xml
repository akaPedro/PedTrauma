<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PedTrauma" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/azul_pedtrauma</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/vermelho_pedtrauma</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/vermelho_pedtrauma</item>
        <item name="android:colorBackground">@color/fundo_cinza</item>
        <item name="colorOnBackground">@color/texto_escuro</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/texto_escuro</item>
    </style>

    <style name="Theme.PedTrauma" parent="Base.Theme.PedTrauma" />

    <!-- Campo de senha com sublinhado e ícone de visibilidade (olho) -->
    <style name="CampoSenha" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxStrokeColor">@color/texto_escuro</item>
        <item name="endIconMode">password_toggle</item>
        <item name="endIconTint">@color/texto_escuro</item>
        <item name="hintEnabled">false</item>
    </style>
</resources>